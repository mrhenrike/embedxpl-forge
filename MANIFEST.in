# Author: André Henrique (@mrhenrike) | União Geek — https://github.com/Uniao-Geek
#
# Controls what goes into the SOURCE DISTRIBUTION (sdist / .tar.gz).
# The wheel (.whl) already contains only embedxpl* via pyproject.toml.
#
# Include: package runtime files + essential metadata
# Exclude: dev tools, docs, CI files, generated artifacts

# === Essential metadata ===
include README.md
include README.pt-BR.md
include LICENSE
include CHANGELOG.md
include pyproject.toml
include requirements.txt

# === Package data — runtime resources ===
recursive-include embedxpl/resources/catalogs     *.json
recursive-include embedxpl/resources/wordlists    *.txt
recursive-include embedxpl/resources/ssh_keys     *.json *.key
recursive-include embedxpl/resources/vendors      *.dat *.csv
recursive-include embedxpl/resources/mibs         *
recursive-include embedxpl/resources/ml           *.json

# IEEE OUI database (used at runtime for MAC vendor lookup)
include embedxpl/data/oui.txt

# RTSP resources (routes + credentials dictionaries)
recursive-include embedxpl/resources/rtsp *.txt *.json

# Nmap NSE scripts (installed via: python -m embedxpl.nse install)
recursive-include nse *.nse

# === Explicit exclusions from sdist ===

# Dev tools — not part of runtime
prune tools

# Documentation — not needed for package execution
prune docs

# CI / CD — not needed for package users
exclude .github
prune .github
exclude .travis.yml
prune .travis

# Legacy packaging
exclude setup.py
exclude Makefile

# Generated artifacts — never ship to PyPI
exclude docs/COVERAGE_MATRIX.md
exclude docs/COVERAGE_MATRIX.txt
exclude embedxpl/resources/catalogs/arsenal_index.json
exclude embedxpl/modules/audit_report.json

# Python artifacts
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.so
global-exclude *.pyd
global-exclude .env
global-exclude *.log
global-exclude .DS_Store
recursive-exclude .log *
recursive-exclude .git *
recursive-exclude .venv *
recursive-exclude venv *
