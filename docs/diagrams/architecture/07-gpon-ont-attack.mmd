%% EmbedXPL-Forge — GPON ONT Attack Surface Map (en-US)
%% Validated against Huawei EG8145X6-10 (OptiXstar) and EG8145V5-V2 (EchoLife)
flowchart LR
  subgraph ISP["ISP / Carrier Side"]
    OLT["OLT — Optical Line Terminal\nOMCI management channel\nSN/LOID authentication"]
    ACS["ACS — Auto Config Server\nTR-069/CWMP provisioning\nFirmware push · config wipe"]
  end

  subgraph ONT["GPON ONT / CPE — Attack Surface"]
    GPON_IF["GPON Interface\nXGS-PON / GPON uplink\n⚠ out of EmbedXPL scope"]
    WEBUI["Web UI — HTTP :80\nBBSP/ASP stack\nDopra Linux 5.10"]
    MGMT["Management Port :37443\nTR-069 listener\n◐ ISP-only access"]
    UPNP_SVC["UPnP IGD — port 49652\nWANIPConnection:1\nlibupnp 1.14.12"]
    WIFI_SVC["Wi-Fi AP (2.4G + 5G)\nWPA2/WPA3 PSK\nEasyMesh controller"]
    SNMP_SVC["SNMP — UDP :161\nCommunity: public (common)"]
    TELNET_SVC["Telnet :23 / SSH :22\nFiltered (ISP firewall)\nEnable via config patch"]
    UART["UART/JTAG — Physical\nRoot shell (Dopra Linux)"]
  end

  subgraph LAN["LAN / Attacker Side"]
    ATK["Attacker on LAN\n192.168.x.y"]
    VICTIM["Admin browser\n(logged into Web UI)"]
  end

  subgraph MODULES["EmbedXPL-Forge Modules"]
