    M6["eg8145x6_epuser_firewall_bypass\nCVE-2025-49599"]
    M7["eg8145x6_csrf_payload_generator\nPhishing / DNS hijack payloads"]
    M8["eg8145x6_dns_poison_csrf\nDNS poisoning via CSRF"]
    M9["eg8145x6_wifi_credential_extractor\nPSK / PPPoE extraction"]
    M10["eg8145x6_autopwn\n9-phase chained exploit"]
    M11["generic/upnp/igd_exploit\nUPnP full exploitation"]
  end

