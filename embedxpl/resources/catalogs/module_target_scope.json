{
  "version": "1.1.0",
  "description": "EmbedXPL-Forge target scope: routers, L2/L3 switches, ISP CPE/SOHO edge, TAPs. Firewall / NGFW modules: see FirewallXPL-Forge.",
  "operational_policy": {
    "prohibited_in_project_scope": [
      "operational_botnets_and_c2_infrastructure",
      "malware_persistence_campaigns_against_third_parties",
      "intentional_device_bricking_or_destructive_floods_outside_authorized_lab"
    ],
    "note": "EmbedXPL-Forge (edge) does not provide turnkey botnet/C2. Firewall / NGFW lab coverage lives in FirewallXPL-Forge."
  },
  "default_allow_classes": [
    "router",
    "switch",
    "soho_edge",
    "tap",
    "isp_cpe"
  ],
  "domain_defaults": {
    "exploits": [
      "router",
      "switch",
      "soho_edge",
      "tap",
      "isp_cpe"
    ],
    "creds": [
      "router",
      "switch",
      "soho_edge",
      "isp_cpe"
    ],
    "scanners": [
      "router",
      "switch",
      "soho_edge",
      "isp_cpe"
    ]
  },
  "prefix_rules": [
    {
      "prefix": "generic/",
      "allow": [
        "router",
        "switch",
        "soho_edge",
        "tap",
        "isp_cpe"
      ]
    },
    {
      "prefix": "switches/cisco/",
      "allow": [
        "switch"
      ]
    },
    {
      "prefix": "switches/dlink/",
      "allow": [
        "switch"
      ]
    },
    {
      "prefix": "routers/cisco/catalyst",
      "allow": [
        "switch",
        "router"
      ]
    },
    {
      "prefix": "routers/cisco/rv",
      "allow": [
        "router",
        "isp_cpe"
      ]
    },
    {
      "prefix": "routers/juniper/",
      "allow": [
        "switch",
        "router"
      ]
    },
    {
      "prefix": "routers/huawei/",
      "allow": [
        "router",
        "switch",
        "isp_cpe"
      ]
    },
    {
      "prefix": "routers/ubiquiti/",
      "allow": [
        "router",
        "switch"
      ]
    },
    {
      "prefix": "soho_edge/",
      "allow": [
        "soho_edge",
        "isp_cpe"
      ]
    }
  ],
  "file_overrides": {
    "generic/http_form_char_by_char_oracle.py": [
      "router",
      "switch",
      "soho_edge",
      "tap",
      "isp_cpe"
    ]
  },
  "note": "Wireless / BLE modules live in WirelessXPL-Forge. Firewall / NGFW modules live in FirewallXPL-Forge."
}
