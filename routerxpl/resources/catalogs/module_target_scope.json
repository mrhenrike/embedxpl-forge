{
  "version": "1.0.0",
  "description": "Maps module paths (routers/foo/bar.py under exploits/ or creds/) to allowed target classes. AutoPwn option target_device_class filters modules. Value 'multi' disables filtering.",
  "operational_policy": {
    "prohibited_in_project_scope": [
      "operational_botnets_and_c2_infrastructure",
      "malware_persistence_campaigns_against_third_parties",
      "intentional_device_bricking_or_destructive_floods_outside_authorized_lab"
    ],
    "note": "RouterXPL-Forge does not provide turnkey botnet/C2, zombie recruitment, or bricking modules. Use authorized lab tooling for controlled resilience tests."
  },
  "default_allow_classes": [
    "router",
    "switch",
    "isp_cpe"
  ],
  "domain_defaults": {
    "exploits": [
      "router",
      "switch",
      "isp_cpe"
    ],
    "creds": [
      "router",
      "switch",
      "isp_cpe"
    ]
  },
  "prefix_rules": [
    {
      "prefix": "generic/",
      "allow": [
        "router",
        "switch",
        "fw",
        "ngfw",
        "isp_cpe"
      ]
    },
    {
      "prefix": "routers/fortinet/",
      "allow": [
        "fw",
        "ngfw"
      ]
    },
    {
      "prefix": "routers/paloalto/",
      "allow": [
        "fw",
        "ngfw"
      ]
    },
    {
      "prefix": "routers/checkpoint/",
      "allow": [
        "fw",
        "ngfw"
      ]
    },
    {
      "prefix": "routers/sonicwall/",
      "allow": [
        "fw",
        "ngfw"
      ]
    },
    {
      "prefix": "routers/sophos/",
      "allow": [
        "fw",
        "ngfw"
      ]
    },
    {
      "prefix": "routers/watchguard/",
      "allow": [
        "fw",
        "ngfw"
      ]
    },
    {
      "prefix": "misc/watchguard/",
      "allow": [
        "fw",
        "ngfw"
      ]
    },
    {
      "prefix": "routers/cisco/catalyst",
      "allow": [
        "switch",
        "router"
      ]
    },
    {
      "prefix": "routers/cisco/firepower",
      "allow": [
        "fw",
        "ngfw"
      ]
    },
    {
      "prefix": "routers/cisco/rv",
      "allow": [
        "router",
        "isp_cpe"
      ]
    },
    {
      "prefix": "routers/juniper/",
      "allow": [
        "switch",
        "router",
        "fw",
        "ngfw"
      ]
    },
    {
      "prefix": "routers/huawei/",
      "allow": [
        "router",
        "switch",
        "isp_cpe",
        "fw"
      ]
    },
    {
      "prefix": "routers/aruba/",
      "allow": [
        "switch",
        "router",
        "fw"
      ]
    },
    {
      "prefix": "routers/ubiquiti/",
      "allow": [
        "router",
        "switch"
      ]
    }
  ],
  "file_overrides": {
    "generic/http_form_char_by_char_oracle.py": [
      "router",
      "switch",
      "fw",
      "ngfw",
      "isp_cpe"
    ]
  }
}
